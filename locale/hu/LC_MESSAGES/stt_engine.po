"\n"
"Leállítás..."

#: stt_engine.py:702
msgid "STT Engine - USB Mic"
msgstr "STT motor - USB mikrofon"

#: stt_engine.py:703
msgid ""
"\n"
"Usage: python3 stt_engine.py [--mic-device <id-or-name>] [--lang-target "
"<language-code>] [--native-lang-target <language-code>] [--whisper-model "
"<model-name-or-path>] [--test] [--list-devices] [--ui-lang <language-code>]"
msgstr ""
"\n"
"Használat: python3 stt_engine.py [--mic-device <azonosító-vagy-név>] [--lang-"
"target <nyelvkód>] [--native-lang-target <nyelvkód>] [--whisper-model "
"<modellnév-vagy-elérési-út>] [--test] [--list-devices] [--ui-lang <nyelvkód>]"

#: stt_engine.py:704
msgid ""
"  --mic-device        Force a specific input device (index or name substring)"
msgstr ""
"  --mic-device        Egy adott bemeneti eszköz kényszerítése (index vagy "
"névrészlet)"

#: stt_engine.py:705
msgid ""
"  --lang-target       Force a specific transcription language (default: auto-"
"detect)"
msgstr ""
"  --lang-target       Egy adott átirat-nyelv kényszerítése (alapértelmezett: "
"automatikus felismerés)"

#: stt_engine.py:706
msgid ""
"  --native-lang-target  Also allow this language (e.g. to code-switch and "
"ask for help), picked between it and --lang-target per utterance"
msgstr ""
"  --native-lang-target  Ennek a nyelvnek az engedélyezése is (pl. "
"nyelvváltáshoz segítségkéréskor), megnyilatkozásonként választva e és a --"
"lang-target között"

#: stt_engine.py:707
msgid ""
"  --whisper-model     Whisper model name or path to use for transcription "
"(default: env WHISPER_MODEL or 'small')"
msgstr ""
"  --whisper-model     Whisper modell neve vagy elérési útja az átiratkészítéshez "
"(alapértelmezett: WHISPER_MODEL környezeti változó vagy 'small')"

#: stt_engine.py:708
msgid "  --list-devices      Show all available audio input/output devices"
msgstr ""
"  --list-devices      Az összes elérhető audio be- és kimeneti eszköz "
"megjelenítése"

#: stt_engine.py:709
msgid "  --test           Record ~3s and play back (quick audio sanity check)"
msgstr "  --test           ~3s felvétel és lejátszás (gyors hangellenőrzés)"

#: stt_engine.py:710
msgid ""
"  --ui-lang        Language for this CLI's own text, e.g. en/hu (default: "
"env UI_LANGUAGE or system locale)"
msgstr ""
"  --ui-lang        Ennek a parancssori eszköznek a saját nyelve, pl. en/hu "
"(alapértelmezett: UI_LANGUAGE környezeti változó vagy rendszernyelv)"

#: stt_engine.py:713
msgid "Available audio devices:"
msgstr "Elérhető audioeszközök:"

