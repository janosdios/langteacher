#: llm_engine.py:429
msgid "Usage: --ui-lang <language-code>"
msgstr "Használat: --ui-lang <nyelvkód>"

#: llm_engine.py:432
msgid "LLM Engine - llama.cpp tutor client"
msgstr "LLM motor - llama.cpp tanár kliens"

#: llm_engine.py:433
msgid ""
"\n"
"Usage: python3 llm_engine.py [--host <ip-or-hostname>] [--port <port>] [--"
"lang-target <language>] [--native-lang <language>] [--level <cefr-level>] [--"
"practice-mode <mode>] [--custom-goal <filename>] [--debug] [--ui-lang "
"<language-code>]"
msgstr ""
"\n"
"Használat: python3 llm_engine.py [--host <ip-cím-vagy-hosztnév>] [--port "
"<port>] [--lang-target <nyelv>] [--native-lang <nyelv>] [--level <cefr-"
"szint>] [--practice-mode <mód>] [--custom-goal <fájlnév>] [--debug] [--ui-"
"lang <nyelvkód>]"

#: llm_engine.py:434
msgid ""
"  --host          llama.cpp server host (default: env LLAMACPP_HOST or "
"127.0.0.1)"
msgstr ""
"  --host          llama.cpp szerver hosztja (alapértelmezett: LLAMACPP_HOST "
"környezeti változó vagy 127.0.0.1)"

#: llm_engine.py:435
msgid ""
"  --port          llama.cpp server port (default: env LLAMACPP_PORT or 8080)"
msgstr ""
"  --port          llama.cpp szerver portja (alapértelmezett: LLAMACPP_PORT "
"környezeti változó vagy 8080)"

#: llm_engine.py:436
msgid ""
"  --lang-target   Target language the tutor teaches (default: env "
"TARGET_LANGUAGE or German)"
msgstr ""
"  --lang-target   A tanár által tanított célnyelv (alapértelmezett: "
"TARGET_LANGUAGE környezeti változó vagy német)"

#: llm_engine.py:437
msgid ""
"  --native-lang   Student's native language, for code-switch fallback and "
"quiz/translation modes (default: env NATIVE_LANGUAGE or English)"
msgstr ""
"  --native-lang   A diák anyanyelve, a nyelvváltó kisegítő szabályhoz és a "
"kvíz/fordítás módokhoz (alapértelmezett: NATIVE_LANGUAGE környezeti változó "
"vagy angol)"

#: llm_engine.py:438
msgid ""
"  --level         Student's CEFR level, e.g. A1/A2/B1/B2 (default: env "
"TEACHER_LEVEL or B1)"
msgstr ""
"  --level         A diák CEFR szintje, pl. A1/A2/B1/B2 (alapértelmezett: "
"TEACHER_LEVEL környezeti változó vagy B1)"

#: llm_engine.py:439
#, python-brace-format
msgid "  --practice-mode Practice mode: {modes} (default: '{default_mode}')"
msgstr ""
"  --practice-mode Gyakorlási mód: {modes} (alapértelmezett: '{default_mode}')"

#: llm_engine.py:443
msgid ""
"  --custom-goal   Filename of a .md file in custom_goals/ to use as the "
"goal; required when --practice-mode is 'custom' (and implies it if --"
"practice-mode is omitted)"
msgstr ""
"  --custom-goal   A custom_goals/ mappában lévő .md fájl neve célként; "
"kötelező, ha a --practice-mode értéke 'custom' (és ezt a módot jelenti "
"akkor is, ha a --practice-mode nincs megadva)"

#: llm_engine.py:444
msgid ""
"  --debug         Enable debug-level logging (e.g. the full tutor system "
"prompt) to logs/llm_engine.log"
msgstr ""
"  --debug         Debug szintű naplózás bekapcsolása (pl. a tanár teljes "
"rendszer promptja) a logs/llm_engine.log fájlba"

#: llm_engine.py:445
msgid ""
"  --ui-lang       Language for this CLI's own text, e.g. en/hu (default: env "
"UI_LANGUAGE or system locale)"
msgstr ""
"  --ui-lang       Ennek a parancssori eszköznek a saját nyelve, pl. en/hu "
"(alapértelmezett: UI_LANGUAGE környezeti változó vagy rendszernyelv)"

#: llm_engine.py:452
msgid "Usage: --host <ip-or-hostname>"
msgstr "Használat: --host <ip-cím-vagy-hosztnév>"

#: llm_engine.py:457
msgid "Usage: --port <port>"
msgstr "Használat: --port <port>"

#: llm_engine.py:462
msgid "Usage: --lang-target <language>"
msgstr "Használat: --lang-target <nyelv>"

#: llm_engine.py:477
msgid "Usage: --native-lang <language>"
msgstr "Használat: --native-lang <nyelv>"

#: llm_engine.py:482
msgid "Usage: --level <cefr-level>"
msgstr "Használat: --level <cefr-szint>"

#: llm_engine.py:493
msgid "Usage: --practice-mode <mode>"
msgstr "Használat: --practice-mode <mód>"

#: llm_engine.py:504
msgid "Usage: --custom-goal <filename>"
msgstr "Használat: --custom-goal <fájlnév>"

#: llm_engine.py:518
msgid "Error: --practice-mode custom requires --custom-goal <filename>."
msgstr ""
"Hiba: a --practice-mode custom értékéhez kötelező a --custom-goal <fájlnév>."

#: llm_engine.py:522
#, python-brace-format
msgid "Error: custom goal file '{name}' not found in custom_goals/."
msgstr ""
"Hiba: a(z) '{name}' egyéni célfájl nem található a custom_goals/ mappában."

#: llm_engine.py:527
#, python-brace-format
msgid "Could not reach llama.cpp server at {url}"
msgstr "Nem sikerült elérni a llama.cpp szervert itt: {url}"

#: llm_engine.py:530
#, python-brace-format
msgid "Chatting with your {lang} tutor ({level}). Ctrl+C to quit.\n"
msgstr "Beszélgetés a(z) {lang} tanároddal ({level}). Kilépés: Ctrl+C.\n"

#: llm_engine.py:535
msgid "You: "
msgstr "Te: "

#: llm_engine.py:538
msgid "Tutor: "
msgstr "Tanár: "

#: llm_engine.py:543
msgid ""
"\n"
"Bye!"
msgstr ""
"\n"
"Viszlát!"

