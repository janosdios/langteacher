#: languages.py:162
msgid "Please select a language: "
msgstr "Válassz egy nyelvet: "

#: languages.py:164 languages.py:181 languages.py:201
msgid "Error! Please enter a number!"
msgstr "Hiba! Adj meg egy számot!"

#: languages.py:168
msgid "Error! Please select a valid language!"
msgstr "Hiba! Válassz egy érvényes nyelvet!"

#: languages.py:179
msgid "Please select a CEFR level: "
msgstr "Válassz egy CEFR szintet: "

#: languages.py:185
msgid "Error! Please select a valid level!"
