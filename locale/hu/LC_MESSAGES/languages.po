#: languages.py:154
msgid "Please select a language: "
msgstr "Válassz egy nyelvet: "

#: languages.py:156 languages.py:173 languages.py:193
msgid "Error! Please enter a number!"
msgstr "Hiba! Adj meg egy számot!"

#: languages.py:160
msgid "Error! Please select a valid language!"
msgstr "Hiba! Válassz egy érvényes nyelvet!"

#: languages.py:171
msgid "Please select a CEFR level: "
msgstr "Válassz egy CEFR szintet: "

#: languages.py:177
msgid "Error! Please select a valid level!"
msgstr "Hiba! Válassz egy érvényes szintet!"

#: languages.py:191
msgid "Please select your native language: "
msgstr "Válaszd ki az anyanyelvedet: "

#: languages.py:199
msgid "Error! Please select a valid option!"
msgstr "Hiba! Válassz egy érvényes lehetőséget!"

#: languages.py:214
msgid "Please type your native language: "
msgstr "Írd be az anyanyelvedet: "

#: languages.py:218
#, python-brace-format
msgid "Error! '{typed}' isn't a recognized language name. Please try again."
msgstr "Hiba! '{typed}' nem felismert nyelvnév. Próbáld újra."
