#: tts_engine.py:259
msgid "No available output device found!"
msgstr "Nem található elérhető kimeneti eszköz!"

#: tts_engine.py:260
msgid "Application terminated!"
msgstr "Az alkalmazás leállt!"

#: tts_engine.py:267
msgid "Please select an output device: "
msgstr "Válassz egy kimeneti eszközt: "

#: tts_engine.py:270
msgid "Error! Please select a valid output device!"
msgstr "Hiba! Válassz egy érvényes kimeneti eszközt!"

#: tts_engine.py:324
msgid "0: (none - auto voice)"
msgstr "0: (nincs - automatikus hang)"

#: tts_engine.py:330
msgid "Please select a reference voice: "
msgstr "Válassz egy referencia hangot: "

#: tts_engine.py:332
msgid "Error! Please enter a number!"
msgstr "Hiba! Adj meg egy számot!"

#: tts_engine.py:338
msgid "Error! Please select a valid option!"
msgstr "Hiba! Válassz egy érvényes lehetőséget!"

#: tts_engine.py:433 tts_engine.py:609
#, python-brace-format
msgid ""
"\n"
"Error: {error}"
msgstr ""
"\n"
"Hiba: {error}"

#: tts_engine.py:449
msgid "Usage: --ui-lang <language-code>"
msgstr "Használat: --ui-lang <nyelvkód>"

#: tts_engine.py:455
msgid "Usage: --engine <omnivoice|piper|auto>"
msgstr "Használat: --engine <omnivoice|piper|auto>"

#: tts_engine.py:461
msgid "Usage: --playback-target <output-id-or-name>"
msgstr "Használat: --playback-target <kimenet-azonosító-vagy-név>"

#: tts_engine.py:467
msgid "Usage: --lang-target <language-code>"
msgstr "Használat: --lang-target <nyelvkód>"

#: tts_engine.py:473
msgid "Usage: --instruct <voice-style-description>"
msgstr "Használat: --instruct <hangstílus-leírás>"

#: tts_engine.py:479
msgid "Usage: --ref-audio <path-or-name-in-samples-dir>"
msgstr "Használat: --ref-audio <útvonal-vagy-név-a-samples-mappában>"

#: tts_engine.py:485
msgid "Usage: --ref-text <transcript-of-reference-audio>"
msgstr "Használat: --ref-text <a-referencia-hang-átirata>"

#: tts_engine.py:499
#, python-brace-format
msgid "Warning: {error} -- keeping current voice."
msgstr "Figyelmeztetés: {error} -- a jelenlegi hang megtartása."

#: tts_engine.py:520
msgid ""
"\n"
"\n"
"Shutting down..."
msgstr ""
"\n"
"\n"
"Leállítás..."

#: tts_engine.py:528
msgid "TTS Engine - OmniVoice / Piper"
msgstr "TTS motor - OmniVoice / Piper"

#: tts_engine.py:529
msgid ""
"\n"
"Usage: python3 tts_engine.py [--engine <omnivoice|piper|auto>] [--playback-"
"target <id-or-name>] [--lang-target <language-code>] [--instruct <voice-"
"style>] [--ref-audio <path-or-name>] [--ref-text <transcript>] [--test] [--"
"list-devices] [--list-voices] [--ui-lang <language-code>]"
msgstr ""
"\n"
"Használat: python3 tts_engine.py [--engine <omnivoice|piper|auto>] [--"
"playback-target <azonosító-vagy-név>] [--lang-target <nyelvkód>] [--instruct "
"<hangstílus>] [--ref-audio <útvonal-vagy-név>] [--ref-text <átirat>] [--"
"test] [--list-devices] [--list-voices] [--ui-lang <nyelvkód>]"

#: tts_engine.py:530
msgid ""
"  --engine           TTS backend to use: omnivoice (voice cloning/design), "
"piper (lightweight, e.g. for a Raspberry Pi), or auto (default: env "
"TTS_ENGINE or 'auto')"
msgstr ""
"  --engine           Használandó TTS motor: omnivoice (hangklónozás/-"
"tervezés), piper (könnyűsúlyú, pl. Raspberry Pi-hez), vagy auto "
"(alapértelmezett: TTS_ENGINE környezeti változó vagy 'auto')"

#: tts_engine.py:531
msgid ""
"  --playback-target  Force a specific output device (index or name substring)"
msgstr ""
"  --playback-target  Egy adott kimeneti eszköz kényszerítése (index vagy "
"névrészlet)"

#: tts_engine.py:532
msgid ""
"  --lang-target      Force a specific synthesis language (default: auto)"
msgstr ""
"  --lang-target      Egy adott szintézisnyelv kényszerítése "
"(alapértelmezett: auto)"

#: tts_engine.py:533
msgid ""
"  --instruct         Voice design instruction, e.g. \"male, British accent"
"\" (omnivoice only)"
msgstr ""
"  --instruct         Hangtervezési utasítás, pl. \"male, British accent\" "
"(csak omnivoice esetén)"

#: tts_engine.py:534
msgid ""
"  --ref-audio        Reference audio for voice cloning (path, or name/"
"substring of a file in samples/) (omnivoice only)"
msgstr ""
"  --ref-audio        Referencia hang a hangklónozáshoz (útvonal, vagy egy "
"fájl neve/névrészlete a samples/ mappában) (csak omnivoice esetén)"

#: tts_engine.py:535
msgid ""
"  --ref-text         Transcript of the reference audio (default: auto-"
"transcribed) (omnivoice only)"
msgstr ""
"  --ref-text         A referencia hang átirata (alapértelmezett: automatikus "
"átirat) (csak omnivoice esetén)"

#: tts_engine.py:536
msgid "  --list-devices     Show all available audio input/output devices"
msgstr ""
"  --list-devices     Az összes elérhető audio be- és kimeneti eszköz "
"megjelenítése"

#: tts_engine.py:537
msgid ""
"  --list-voices      Show reference audio files available in samples/ "
"(omnivoice only)"
msgstr ""
"  --list-voices      A samples/ mappában elérhető referencia hangfájlok "
"megjelenítése (csak omnivoice esetén)"

#: tts_engine.py:538
msgid ""
"  --check-updates    Check the HF Hub for a newer model revision instead of "
"using the local cache offline (omnivoice only)"
msgstr ""
"  --check-updates    Új modellverzió keresése a HF Hub-on, ahelyett hogy a "
"helyi gyorsítótárat használná offline módban (csak omnivoice esetén)"

#: tts_engine.py:539
msgid ""
"  --test             Synthesize and play a short built-in phrase (quick "
"sanity check)"
msgstr ""
"  --test             Egy rövid beépített mondat szintetizálása és lejátszása "
"(gyors ellenőrzés)"

#: tts_engine.py:540
msgid ""
"  --ui-lang          Language for this CLI's own text, e.g. en/hu (default: "
"env UI_LANGUAGE or system locale)"
msgstr ""
"  --ui-lang          Ennek a parancssori eszköznek a saját nyelve, pl. en/hu "
"(alapértelmezett: UI_LANGUAGE környezeti változó vagy rendszernyelv)"

#: tts_engine.py:546
msgid "Output devices (usable with --playback-target <index>):"
msgstr "Kimeneti eszközök (a --playback-target <index> kapcsolóval használhatók):"

#: tts_engine.py:551
msgid "  (none found)"
msgstr "  (nincs találat)"

