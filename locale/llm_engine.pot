#: llm_engine.py:381
msgid "LLM Engine - llama.cpp tutor client"
msgstr ""

#: llm_engine.py:382
msgid ""
"\n"
"Usage: python3 llm_engine.py [--host <ip-or-hostname>] [--port <port>] [--"
"lang-target <language>] [--level <cefr-level>] [--ui-lang <language-code>]"
msgstr ""

#: llm_engine.py:383
msgid ""
"  --host          llama.cpp server host (default: env LLAMACPP_HOST or "
"127.0.0.1)"
msgstr ""

#: llm_engine.py:384
msgid ""
"  --port          llama.cpp server port (default: env LLAMACPP_PORT or 8080)"
msgstr ""

#: llm_engine.py:385
msgid ""
"  --lang-target   Target language the tutor teaches (default: env "
"TARGET_LANGUAGE or German). Also"
msgstr ""

#: llm_engine.py:386
msgid ""
"                  switches the tutor name to match, per languages.py, unless "
"env TUTOR_NAME is set."
msgstr ""

#: llm_engine.py:387
msgid ""
"  --level         Student's CEFR level, e.g. A1/A2/B1/B2 (default: env "
"TEACHER_LEVEL or B1)"
msgstr ""

#: llm_engine.py:388
msgid ""
"  --ui-lang       Language for this CLI's own text, e.g. en/hu (default: env "
"UI_LANGUAGE or system locale)"
msgstr ""

