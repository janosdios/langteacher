#: stt_engine.py:808
msgid ""
"\n"
"Usage: python3 stt_engine.py [--mic-device <id-or-name>] [--playback-target "
"<id-or-name>] [--lang-target <language-code>] [--native-lang-target "
"<language-code>] [--whisper-model <model-name-or-path>] [--test] [--list-"
"devices] [--ui-lang <language-code>] [--debug]"
msgstr ""

#: stt_engine.py:809
msgid ""
"  --mic-device        Force a specific input device (index or name substring)"
msgstr ""

#: stt_engine.py:810
msgid ""
"  --playback-target   Force a specific output device for --test playback "
"(index or name substring)"
msgstr ""

#: stt_engine.py:811
msgid ""
"  --lang-target       Force a specific transcription language, e.g. en/hu "
"(default: auto-detect)"
msgstr ""

#: stt_engine.py:812
msgid ""
"  --native-lang-target  Also allow this language (e.g. to code-switch and "
"ask for help), picked between it and --lang-target per utterance"
msgstr ""

#: stt_engine.py:813
msgid ""
"  --whisper-model     Whisper model name or path to use for transcription "
"(default: env WHISPER_MODEL or 'small')"
msgstr ""

#: stt_engine.py:814
msgid "  --list-devices      Show all available audio input/output devices"
msgstr ""

#: stt_engine.py:815
msgid "  --test           Record ~3s and play back (quick audio sanity check)"
msgstr ""

#: stt_engine.py:816
msgid ""
"  --ui-lang        Language for this CLI's own text, e.g. en/hu (default: "
"env UI_LANGUAGE or system locale)"
msgstr ""

