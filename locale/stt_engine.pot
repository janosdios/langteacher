#: stt_engine.py:729
msgid ""
"  --mic-device        Force a specific input device (index or name substring)"
msgstr ""

#: stt_engine.py:730
msgid ""
"  --lang-target       Force a specific transcription language, e.g. en/hu "
"(default: auto-detect)"
msgstr ""

#: stt_engine.py:731
msgid ""
"  --native-lang-target  Also allow this language (e.g. to code-switch and "
