#: main.py:335
msgid "LangTeacher - voice-based language tutor"
msgstr ""

#: main.py:336
msgid ""
"\n"
"Usage: python3 main.py [--version] [--debug] [--no-recap] [--whisper-model "
"<model-name-or-path>] [--tts-engine <omnivoice|piper|auto>] [--tutor-host "
"<ip-or-hostname>] [--tutor-port <port>] [--rag-host <ip-or-hostname>] [--rag-"
"port <port>] [--practice-mode <mode>] [--custom-goal <filename>] [--ui-lang "
"<language-code>]"
msgstr ""

#: main.py:337
msgid "  --version        Print the installed version and exit"
msgstr ""

#: main.py:338
msgid ""
"  --debug          Enable debug-level logging (e.g. the full tutor system "
"prompt) to logs/*.log"
msgstr ""

#: main.py:339
msgid ""
"  --no-recap       Start with a clean slate, ignoring any previous session's "
"recap"
msgstr ""

#: main.py:340
msgid ""
"  --whisper-model  Whisper model name or path to use for transcription "
"(default: env WHISPER_MODEL or 'small'); pick according to platform/"
"language, e.g. a smaller model on a Raspberry Pi or a language-specific fine-"
"tune"
msgstr ""

#: main.py:341
msgid ""
"  --tts-engine     TTS backend to use: omnivoice (voice cloning/design), "
"piper (lightweight, e.g. for a Raspberry Pi), or auto (default: env "
"TTS_ENGINE or 'auto')"
msgstr ""

#: main.py:342
msgid ""
"  --tutor-host     llama.cpp server host for the tutor LLM (default: env "
"LLAMACPP_HOST or 127.0.0.1)"
msgstr ""

#: main.py:343
msgid ""
"  --tutor-port     llama.cpp server port for the tutor LLM (default: env "
"LLAMACPP_PORT or 8080)"
msgstr ""

#: main.py:344
msgid ""
"  --rag-host       llama.cpp server host for the RAG embedding model "
"(default: env EMBED_HOST or 127.0.0.1)"
msgstr ""

#: main.py:345
msgid ""
"  --rag-port       llama.cpp server port for the RAG embedding model "
"(default: env EMBED_PORT or 8081)"
msgstr ""

#: main.py:346
#, python-brace-format
msgid ""
"  --practice-mode  Practice mode, skipping the interactive picker: {modes} "
"(default: '{default_mode}')"
msgstr ""

#: main.py:350
msgid ""
"  --custom-goal    Filename of a .md file in custom_goals/ to use as the "
"session's goal; required when --practice-mode is 'custom' (and implies it if "
"--practice-mode is omitted)"
msgstr ""

#: main.py:351
msgid ""
"  --ui-lang        Language for this CLI's own text, e.g. en/hu (default: "
"env UI_LANGUAGE or system locale)"
msgstr ""

#: main.py:364
msgid "Usage: --practice-mode <mode>"
msgstr ""

